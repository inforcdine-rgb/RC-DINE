NODE_ENV=development
PORT=5001
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://app.rcdine.com,https://admin.rcdine.com

DB_NAME=rcdine
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql

JWT_SECRET=change_this_to_a_long_random_secret
CRYPTO_SECRET_KEY=must_match_frontend_crypto_secret
PASSWORD_SALT_ROUNDS=12

SEED_ADMIN=false
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_strong_password
ADMIN_PHONE=9999999999
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

EMAIL_USER=
EMAIL_PASS=
SUPPORT_EMAIL=Info.rcdine@gmail.com

WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_EMAIL=mailto:Info.rcdine@gmail.com

RAZORPAY_KEY_ID=
