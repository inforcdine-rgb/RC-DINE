RAZORPAY_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STANDARD_MONTHLY=
STANDARD_YEARLY=

# Fast2SMS Quick SMS (without DLT)
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=q
FAST2SMS_TIMEOUT_MS=10000

# Customer mobile OTP security
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_SENDS_PER_DAY=15
OTP_HASH_SECRET=replace_with_a_different_long_random_secret
CUSTOMER_JWT_SECRET=replace_with_a_long_random_secret
CUSTOMER_TOKEN_EXPIRY=12h
